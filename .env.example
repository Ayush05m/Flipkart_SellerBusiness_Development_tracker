FLIPKART_SELLER_PRODUCTS_URL=https://api.flipkart.net/your-seller-report-or-listings-endpoint
FLIPKART_SELLER_CLIENT_ID=your_client_id
FLIPKART_SELLER_CLIENT_SECRET=your_client_secret

# Optional: use a pre-generated token instead of client credentials.
# FLIPKART_SELLER_ACCESS_TOKEN=your_access_token

# Optional: override the default Flipkart OAuth URL.
# FLIPKART_SELLER_TOKEN_URL=https://api.flipkart.net/oauth-service/oauth/token?grant_type=client_credentials&scope=Seller_Api
